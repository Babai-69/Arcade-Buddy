rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Everyone can read
    match /leaderboard/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == "deya58690@gmail.com" || request.auth.token.email == "tripti.arcade.25@gmail.com");
    }
  }
}
