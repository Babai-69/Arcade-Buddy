rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in ['deya58690@gmail.com', 'tripti.arcade.25@gmail.com'];
    }

    // Leaderboard — public read, admin write only
    match /leaderboard/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users — each user reads/writes only their own, plus admin access
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin();

      // Badge sub-collection
      match /badges/{badgeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        allow read, write: if isAdmin();
      }
    }

    // Queries - any user can create, only admin can read/update/delete
    match /queries/{queryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Config — public read, admin write
    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
